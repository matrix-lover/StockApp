<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StockApp.MainPage"
    Title="Stocks"
    BackgroundColor="#121212">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- SearchBar -->
        <SearchBar
            x:Name="SearchBar"
            Placeholder="Search ticker..."
            Text="{Binding SearchText}"
            Margin="10"
            BackgroundColor="#2E2E2E"
            TextColor="White"
            PlaceholderColor="Gray"
            Grid.Row="0"/>

        <!-- SEARCH RESULTS (TapGesture) -->
        <CollectionView
            x:Name="SearchResultsCollectionView"
            ItemsSource="{Binding SearchResults}"
            HeightRequest="200"
            Margin="10,0"
            IsVisible="{Binding IsSearching}"
            SelectionMode="None" 
            Grid.Row="1">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="5" BackgroundColor="#1E1E1E" CornerRadius="10">
                
                        <!-- Tap на рамке (на всю карточку) -->
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="SearchResultTapped" NumberOfTapsRequired="1" />
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout>
                            <Label Text="{Binding DisplaySymbol}" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="{Binding Description}" TextColor="Gray" FontSize="14"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Main Stock List -->
        <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}" Grid.Row="2">
            <CollectionView
                ItemsSource="{Binding Stocks}"
                Margin="10"
                SelectionMode="None"
                VerticalOptions="FillAndExpand">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="12" Padding="10" Margin="5" BackgroundColor="#1E1E1E" HasShadow="True">
                            <Grid ColumnDefinitions="*,Auto,Auto" VerticalOptions="Center">

                                <Label Text="{Binding Symbol}" FontSize="20" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>

                                <Label Grid.Column="1" Text="{Binding DisplayPrice}" FontSize="20" TextColor="{Binding Color}" VerticalOptions="Center" HorizontalOptions="End"/>

                                <Label Grid.Column="2" Text="{Binding Arrow}" FontSize="20" TextColor="{Binding Color}" VerticalOptions="Center" HorizontalOptions="End" Margin="5,0,0,0"/>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>